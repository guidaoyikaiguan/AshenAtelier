# ===========================================
# shipinbofang Docker 部署环境变量模板
# 复制此文件为 .env 并修改实际值
# ===========================================

# MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_USER=root
MYSQL_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me

# JWT
JWT_SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars

# DeepSeek API (AI 服务使用)
LLM_API_KEY=sk-your-deepseek-api-key

# 七牛云对象存储
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET_NAME=monvshipin
QINIU_DOMAIN=tet31ocbs.hn-bkt.clouddn.com

# AI 功能开关 (GPU 相关功能在 Docker 中不可用)
ASR_ENABLED=false
TTS_ENABLED=false
