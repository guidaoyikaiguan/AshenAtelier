# LLM Configuration
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=shipin

# Shipin Java Backend
SHIPIN_SERVICE_URL=http://localhost:8081

# JWT (must match Java jwt.secret-key)
JWT_SECRET_KEY=abcdefghijklmnopqrstuvwxyz1234567890abcdef

# Moderation thresholds
MODERATION_AUTO_APPROVE_THRESHOLD=0.9
MODERATION_FLAG_THRESHOLD=0.7
MODERATION_AUTO_REJECT_THRESHOLD=0.5

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8084
