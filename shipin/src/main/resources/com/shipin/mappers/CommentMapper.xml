	<!--多条件修改-->
	<update id="updateByParam" parameterType="com.shipin.entity.query.CommentQuery">
		 UPDATE comment c
 		 <set> 
			<if test="bean.userId != null">
				 user_id = #{bean.userId},
			</if>
			<if test="bean.videoId != null">
				 video_id = #{bean.videoId},
			</if>
			<if test="bean.content != null">
				 content = #{bean.content},
			</if>
			<if test="bean.commentTime != null">
