			</if>
			<if test="bean.parentId != null">
				 parent_id = #{bean.parentId},
			</if>
			<if test="bean.likeCount != null">
				 like_count = #{bean.likeCount},
			</if>
			<if test="bean.ifTop != null">
				 if_top = #{bean.ifTop},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete c from comment c
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据CommentId修改-->
	<update id="updateByCommentId" parameterType="com.shipin.entity.po.Comment">
		 UPDATE comment
 		 <set> 
			<if test="bean.userId != null">
				 user_id = #{bean.userId},
			</if>
			<if test="bean.videoId != null">
				 video_id = #{bean.videoId},
			</if>
			<if test="bean.content != null">
