			</if>
			<if test="bean.likeCount != null">
				 like_count = #{bean.likeCount},
			</if>
			<if test="bean.ifTop != null">
				 if_top = #{bean.ifTop},
			</if>
 		 </set>
 		 where comment_id=#{commentId}
	</update>

	<!-- 根据CommentId删除-->
	<delete id="deleteByCommentId">
		delete from comment where comment_id=#{commentId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByCommentId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from comment c where comment_id=#{commentId}
	</select>

	<select id="selectAll" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from comment c
	</select>
