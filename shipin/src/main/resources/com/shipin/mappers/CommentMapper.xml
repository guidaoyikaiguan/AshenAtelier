			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="com.shipin.entity.po.Comment" useGeneratedKeys="true" keyProperty="commentId">
		 INSERT INTO comment(
			 user_id,
			 video_id,
			 content,
			 comment_time,
			 parent_id,
			 like_count,
			 if_top
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.userId},
				 #{item.videoId},
				 #{item.content},
				 #{item.commentTime},
				 #{item.parentId},
				 #{item.likeCount},
				 #{item.ifTop}
			 )
		 </foreach>
	</insert>

