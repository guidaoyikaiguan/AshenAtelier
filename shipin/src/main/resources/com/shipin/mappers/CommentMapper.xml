<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shipin.mappers.CommentMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.shipin.entity.po.Comment">
		<!---->
		<id column="comment_id" property="commentId"  />
		<!---->
		<result column="user_id" property="userId"  />
		<!---->
		<result column="video_id" property="videoId"  />
		<!---->
		<result column="content" property="content"  />
		<!---->
		<result column="comment_time" property="commentTime"  />
		<!---->
		<result column="parent_id" property="parentId"  />
		<!---->
		<result column="like_count" property="likeCount"  />
		<!--是否置顶-->
		<result column="if_top" property="ifTop"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 c.comment_id,c.user_id,c.video_id,c.content,c.comment_time,
		 c.parent_id,c.like_count,c.if_top
	</sql>

	<sql id="base_condition_filed">
			<if test="query.commentId != null">
				 and  c.comment_id = #{query.commentId}
			</if>
			<if test="query.userId != null">
				 and  c.user_id = #{query.userId}
			</if>
			<if test="query.videoId != null">
				 and  c.video_id = #{query.videoId}
			</if>
			<if test="query.content != null and query.content!=''">
				 and  c.content = #{query.content}
			</if>
			<if test="query.commentTime != null and query.commentTime!=''">
				 <![CDATA[ and  c.comment_time=str_to_date(#{query.commentTime}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.parentId != null">
				 and  c.parent_id = #{query.parentId}
			</if>
			<if test="query.likeCount != null">
				 and  c.like_count = #{query.likeCount}
			</if>
			<if test="query.ifTop != null">
				 and  c.if_top = #{query.ifTop}
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.contentFuzzy!= null  and query.contentFuzzy!=''">
				 and  c.content like concat('%', #{query.contentFuzzy}, '%')
			</if>
			<if test="query.commentTimeStart!= null and query.commentTimeStart!=''">
				 <![CDATA[ and  c.comment_time>=str_to_date(#{query.commentTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.commentTimeEnd!= null and query.commentTimeEnd!=''">
				 <![CDATA[ and  c.comment_time< date_sub(str_to_date(#{query.commentTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM comment c <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM comment c <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="com.shipin.entity.po.Comment">
		<selectKey keyProperty="bean.commentId" resultType="Integer" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>
		 INSERT INTO comment
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.videoId != null">
				 video_id,
			</if>
			<if test="bean.content != null">
				 content,
			</if>
			<if test="bean.commentTime != null">
				 comment_time,
			</if>
			<if test="bean.parentId != null">
				 parent_id,
			</if>
			<if test="bean.likeCount != null">
				 like_count,
			</if>
			<if test="bean.ifTop != null">
				 if_top,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.videoId!=null">
				 #{bean.videoId},
			</if>
			<if test="bean.content!=null">
				 #{bean.content},
			</if>
			<if test="bean.commentTime!=null">
				 #{bean.commentTime},
			</if>
			<if test="bean.parentId!=null">
				 #{bean.parentId},
			</if>
			<if test="bean.likeCount!=null">
				 #{bean.likeCount},
			</if>
			<if test="bean.ifTop!=null">
				 #{bean.ifTop},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="com.shipin.entity.po.Comment">
		 INSERT INTO comment
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.commentId != null">
				 comment_id,
			</if>
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.videoId != null">
				 video_id,
			</if>
			<if test="bean.content != null">
				 content,
			</if>
			<if test="bean.commentTime != null">
				 comment_time,
			</if>
			<if test="bean.parentId != null">
				 parent_id,
			</if>
			<if test="bean.likeCount != null">
				 like_count,
			</if>
			<if test="bean.ifTop != null">
				 if_top,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.commentId!=null">
				 #{bean.commentId},
			</if>
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.videoId!=null">
				 #{bean.videoId},
			</if>
			<if test="bean.content!=null">
				 #{bean.content},
			</if>
			<if test="bean.commentTime!=null">
				 #{bean.commentTime},
			</if>
			<if test="bean.parentId!=null">
				 #{bean.parentId},
			</if>
			<if test="bean.likeCount!=null">
				 #{bean.likeCount},
			</if>
			<if test="bean.ifTop!=null">
				 #{bean.ifTop},
			</if>
		 </trim>
		 on DUPLICATE key update 
		 <trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.userId!=null">
				 user_id = VALUES(user_id),
			</if>
			<if test="bean.videoId!=null">
				 video_id = VALUES(video_id),
			</if>
			<if test="bean.content!=null">
