	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 c.carousel_id,c.category_id,c.title,c.cover,c.link,
		 c.sort_order,c.status,c.create_time,c.update_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.carouselId != null">
				 and  c.carousel_id = #{query.carouselId}
			</if>
			<if test="query.categoryId != null">
				 and  c.category_id = #{query.categoryId}
			</if>
			<if test="query.title != null and query.title!=''">
				 and  c.title = #{query.title}
			</if>
			<if test="query.cover != null and query.cover!=''">
				 and  c.cover = #{query.cover}
			</if>
			<if test="query.link != null and query.link!=''">
				 and  c.link = #{query.link}
			</if>
			<if test="query.sortOrder != null">
				 and  c.sort_order = #{query.sortOrder}
			</if>
			<if test="query.status != null">
				 and  c.status = #{query.status}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  c.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.updateTime != null and query.updateTime!=''">
				 <![CDATA[ and  c.update_time=str_to_date(#{query.updateTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.titleFuzzy!= null  and query.titleFuzzy!=''">
				 and  c.title like concat('%', #{query.titleFuzzy}, '%')
			</if>
			<if test="query.coverFuzzy!= null  and query.coverFuzzy!=''">
				 and  c.cover like concat('%', #{query.coverFuzzy}, '%')
			</if>
			<if test="query.linkFuzzy!= null  and query.linkFuzzy!=''">
				 and  c.link like concat('%', #{query.linkFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  c.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  c.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
			<if test="query.updateTimeStart!= null and query.updateTimeStart!=''">
				 <![CDATA[ and  c.update_time>=str_to_date(#{query.updateTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.updateTimeEnd!= null and query.updateTimeEnd!=''">
				 <![CDATA[ and  c.update_time< date_sub(str_to_date(#{query.updateTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM carousel c <include refid="query_condition" />
