		<result column="cover" property="cover"  />
		<!--跳转链接-->
		<result column="link" property="link"  />
		<!--排序权重-->
		<result column="sort_order" property="sortOrder"  />
		<!--状态：1-启用，0-禁用-->
		<result column="status" property="status"  />
		<!--创建时间-->
