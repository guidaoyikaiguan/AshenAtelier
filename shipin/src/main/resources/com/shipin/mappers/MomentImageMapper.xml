<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shipin.mappers.MomentImageMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.shipin.entity.po.MomentImage">
		<!---->
		<id column="image_id" property="imageId"  />
		<!---->
		<result column="moment_id" property="momentId"  />
		<!---->
		<result column="image_url" property="imageUrl"  />
		<!---->
		<result column="sort_order" property="sortOrder"  />
		<!---->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 m.image_id,m.moment_id,m.image_url,m.sort_order,m.create_time
		 
	</sql>

	<sql id="base_condition_filed">
			<if test="query.imageId != null">
				 and  m.image_id = #{query.imageId}
			</if>
			<if test="query.momentId != null">
				 and  m.moment_id = #{query.momentId}
			</if>
			<if test="query.imageUrl != null and query.imageUrl!=''">
				 and  m.image_url = #{query.imageUrl}
			</if>
			<if test="query.sortOrder != null">
				 and  m.sort_order = #{query.sortOrder}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  m.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.imageUrlFuzzy!= null  and query.imageUrlFuzzy!=''">
				 and  m.image_url like concat('%', #{query.imageUrlFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  m.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  m.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM moment_image m <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM moment_image m <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="com.shipin.entity.po.MomentImage">
		<selectKey keyProperty="bean.imageId" resultType="Integer" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>
		 INSERT INTO moment_image
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.momentId != null">
				 moment_id,
			</if>
			<if test="bean.imageUrl != null">
				 image_url,
			</if>
			<if test="bean.sortOrder != null">
				 sort_order,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.momentId!=null">
				 #{bean.momentId},
			</if>
			<if test="bean.imageUrl!=null">
				 #{bean.imageUrl},
			</if>
			<if test="bean.sortOrder!=null">
				 #{bean.sortOrder},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="com.shipin.entity.po.MomentImage">
		 INSERT INTO moment_image
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.imageId != null">
				 image_id,
			</if>
			<if test="bean.momentId != null">
				 moment_id,
			</if>
			<if test="bean.imageUrl != null">
				 image_url,
			</if>
			<if test="bean.sortOrder != null">
				 sort_order,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.imageId!=null">
				 #{bean.imageId},
			</if>
			<if test="bean.momentId!=null">
				 #{bean.momentId},
			</if>
			<if test="bean.imageUrl!=null">
				 #{bean.imageUrl},
			</if>
			<if test="bean.sortOrder!=null">
				 #{bean.sortOrder},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
		 on DUPLICATE key update 
		 <trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.momentId!=null">
				 moment_id = VALUES(moment_id),
			</if>
			<if test="bean.imageUrl!=null">
				 image_url = VALUES(image_url),
			</if>
			<if test="bean.sortOrder!=null">
				 sort_order = VALUES(sort_order),
			</if>
			<if test="bean.createTime!=null">
				 create_time = VALUES(create_time),
			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="com.shipin.entity.po.MomentImage" useGeneratedKeys="true" keyProperty="imageId">
		 INSERT INTO moment_image(
			 moment_id,
			 image_url,
			 sort_order,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.momentId},
				 #{item.imageUrl},
				 #{item.sortOrder},
				 #{item.createTime}
			 )
		 </foreach>
	</insert>

	<!-- 批量新增修改 （批量插入）-->
	<insert id="insertOrUpdateBatch" parameterType="com.shipin.entity.po.MomentImage">
		 INSERT INTO moment_image(
			 moment_id,
			 image_url,
			 sort_order,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.momentId},
				 #{item.imageUrl},
				 #{item.sortOrder},
				 #{item.createTime}
			 )
		 </foreach>
			on DUPLICATE key update 
			moment_id = VALUES(moment_id),
			image_url = VALUES(image_url),
			sort_order = VALUES(sort_order),
			create_time = VALUES(create_time)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="com.shipin.entity.query.MomentImageQuery">
		 UPDATE moment_image m
 		 <set> 
			<if test="bean.momentId != null">
				 moment_id = #{bean.momentId},
			</if>
			<if test="bean.imageUrl != null">
				 image_url = #{bean.imageUrl},
			</if>
			<if test="bean.sortOrder != null">
				 sort_order = #{bean.sortOrder},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete m from moment_image m
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据ImageId修改-->
	<update id="updateByImageId" parameterType="com.shipin.entity.po.MomentImage">
		 UPDATE moment_image
 		 <set> 
			<if test="bean.momentId != null">
				 moment_id = #{bean.momentId},
			</if>
			<if test="bean.imageUrl != null">
				 image_url = #{bean.imageUrl},
			</if>
			<if test="bean.sortOrder != null">
				 sort_order = #{bean.sortOrder},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 where image_id=#{imageId}
	</update>

	<!-- 根据ImageId删除-->
	<delete id="deleteByImageId">
		delete from moment_image where image_id=#{imageId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByImageId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from moment_image m where image_id=#{imageId}
	</select>

</mapper>