	</select>


	<select id="selectUserLikes" resultType="java.lang.Integer">
		select sum(like_count) from video v
		WHERE user_id = #{userId}
	</select>

	<select id="selectUserPlays" resultType="java.lang.Integer">
		select sum(play_count) from video v
		WHERE user_id = #{userId}
	</select>

	<!-- 获取所有已审核通过的视频 -->
	<select id="selectAllApprovedVideos" resultMap="base_result_map">
		SELECT <include refid="base_column_list" /> FROM video v WHERE v.status = '1'
	</select>

	<!-- 根据标签搜索视频 -->
	<select id="selectByTags" resultMap="base_result_map">
		SELECT <include refid="base_column_list" /> FROM video v
		WHERE v.status = 1 AND v.tags LIKE CONCAT('%', #{tag}, '%')
		<if test="query.simplePage!=null">
			limit #{query.simplePage.start},#{query.simplePage.end}
		</if>
	</select>
</mapper>