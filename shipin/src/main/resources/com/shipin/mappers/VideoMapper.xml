	<select id="selectVideo" resultType="com.shipin.entity.po.Video">
		SELECT v.*,u.nick_name from video v  JOIN user u on u.user_id=v.user_id
		WHERE 1=1
		<if test="query.videoId != null">
			AND v.video_id = #{query.videoId}
		</if>
		<if test="query.userId != null">
			AND v.user_id = #{query.userId}
		</if>
		<if test="query.status != null and query.status != ''">
			AND v.status = #{query.status}
		</if>
		<if test="query.simplePage!=null">
			limit #{query.simplePage.start},#{query.simplePage.end}
		</if>
	</select>

	<select id="selectSeeVideo" resultType="com.shipin.entity.po.Video">
		SELECT v.*,u.nick_name,u.avatar from video v  JOIN user u on u.user_id=v.user_id
		WHERE v.status = 1
		  <if test="query.videoId != null">
			AND v.video_id = #{query.videoId}
		</if>
		<if test="query.categroyId != null">
			AND v.categroy_id = #{query.categroyId}
		</if>
		<if test="query.titleFuzzy!= null  and query.titleFuzzy!=''">
			 and  v.title like concat('%', #{query.titleFuzzy}, '%')
		</if>
		<if test="query.simplePage!=null">
			limit #{query.simplePage.start},#{query.simplePage.end}
		</if>
	</select>

