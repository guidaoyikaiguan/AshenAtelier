	<!--实体映射-->
	<resultMap id="base_result_map" type="com.shipin.entity.po.Video">
		<!--视频ID-->
		<id column="video_id" property="videoId"  />
		<!--上传用户ID-->
		<result column="user_id" property="userId"  />
		<!--视频分类ID-->
		<result column="categroy_id" property="categroyId"  />
		<!--视频标题-->
		<result column="title" property="title"  />
		<!--视频描述-->
		<result column="description" property="description"  />
		<!--视频标签-->
		<result column="tags" property="tags"  />
		<!--视频存储路径-->
		<result column="video_url" property="videoUrl"  />
		<!--视频封面图路径-->
		<result column="cover_url" property="coverUrl"  />
		<!--视频时长（秒）-->
		<result column="duration" property="duration"  />
		<!--播放量-->
		<result column="play_count" property="playCount"  />
		<!--点赞数-->
		<result column="like_count" property="likeCount"  />
		<!--评论数-->
		<result column="comment_count" property="commentCount"  />
		<!--状态（0：待审核，1：已通过，2：已拒绝）-->
		<result column="status" property="status"  />
		<!--上传时间-->
		<result column="create_time" property="createTime"  />
		<!--更新时间-->
		<result column="update_time" property="updateTime"  />
		<!--硬币数-->
		<result column="coins_inserted" property="coinsInserted"  />
		<!--收藏数-->
		<result column="follow_count" property="followCount"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 v.video_id,v.user_id,v.categroy_id,v.title,v.description,v.tags,
		 v.video_url,v.cover_url,v.duration,v.play_count,v.like_count,
		 v.comment_count,v.status,v.create_time,v.update_time,v.coins_inserted,v.follow_count
	</sql>

	<sql id="base_condition_filed">
			<if test="query.videoId != null">
				 and  v.video_id = #{query.videoId}
			</if>
			<if test="query.userId != null">
				 and  v.user_id = #{query.userId}
			</if>
			<if test="query.categroyId != null">
				 and  v.categroy_id = #{query.categroyId}
			</if>
			<if test="query.title != null and query.title!=''">
				 and  v.title = #{query.title}
			</if>
			<if test="query.description != null and query.description!=''">
				 and  v.description = #{query.description}
			</if>
			<if test="query.videoUrl != null and query.videoUrl!=''">
				 and  v.video_url = #{query.videoUrl}
			</if>
			<if test="query.coverUrl != null and query.coverUrl!=''">
				 and  v.cover_url = #{query.coverUrl}
			</if>
			<if test="query.duration != null and query.duration!=''">
				 and  v.duration = #{query.duration}
			</if>
			<if test="query.playCount != null and query.playCount!=''">
				 and  v.play_count = #{query.playCount}
			</if>
			<if test="query.likeCount != null and query.likeCount!=''">
				 and  v.like_count = #{query.likeCount}
			</if>
			<if test="query.commentCount != null and query.commentCount!=''">
				 and  v.comment_count = #{query.commentCount}
			</if>
			<if test="query.status != null and query.status!=''">
				 and  v.status = #{query.status}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  v.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.updateTime != null and query.updateTime!=''">
				 <![CDATA[ and  v.update_time=str_to_date(#{query.updateTime}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.coinsInserted != null and query.coinsInserted!=''">
				 and  v.coins_inserted = #{query.coinsInserted}
			</if>
			<if test="query.followCount != null and query.followCount!=''">
				 and  v.follow_count = #{query.followCount}
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.titleFuzzy!= null  and query.titleFuzzy!=''">
				 and  v.title like concat('%', #{query.titleFuzzy}, '%')
			</if>
			<if test="query.descriptionFuzzy!= null  and query.descriptionFuzzy!=''">
				 and  v.description like concat('%', #{query.descriptionFuzzy}, '%')
			</if>
			<if test="query.videoUrlFuzzy!= null  and query.videoUrlFuzzy!=''">
				 and  v.video_url like concat('%', #{query.videoUrlFuzzy}, '%')
			</if>
			<if test="query.coverUrlFuzzy!= null  and query.coverUrlFuzzy!=''">
				 and  v.cover_url like concat('%', #{query.coverUrlFuzzy}, '%')
			</if>
			<if test="query.durationFuzzy!= null  and query.durationFuzzy!=''">
				 and  v.duration like concat('%', #{query.durationFuzzy}, '%')
			</if>
			<if test="query.playCountFuzzy!= null  and query.playCountFuzzy!=''">
				 and  v.play_count like concat('%', #{query.playCountFuzzy}, '%')
			</if>
			<if test="query.likeCountFuzzy!= null  and query.likeCountFuzzy!=''">
				 and  v.like_count like concat('%', #{query.likeCountFuzzy}, '%')
			</if>
			<if test="query.commentCountFuzzy!= null  and query.commentCountFuzzy!=''">
				 and  v.comment_count like concat('%', #{query.commentCountFuzzy}, '%')
			</if>
			<if test="query.statusFuzzy!= null  and query.statusFuzzy!=''">
				 and  v.status like concat('%', #{query.statusFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  v.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  v.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
			<if test="query.updateTimeStart!= null and query.updateTimeStart!=''">
				 <![CDATA[ and  v.update_time>=str_to_date(#{query.updateTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.updateTimeEnd!= null and query.updateTimeEnd!=''">
				 <![CDATA[ and  v.update_time< date_sub(str_to_date(#{query.updateTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
			<if test="query.coinsInsertedFuzzy!= null  and query.coinsInsertedFuzzy!=''">
				 and  v.coins_inserted like concat('%', #{query.coinsInsertedFuzzy}, '%')
			</if>
	 </where>
	</sql>

