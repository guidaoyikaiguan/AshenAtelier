			</if>
			<if test="bean.updatedAt != null">
				 updated_at = #{bean.updatedAt},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete v from video_history v
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据Id修改-->
	<update id="updateById" parameterType="com.shipin.entity.po.VideoHistory">
		 UPDATE video_history
 		 <set> 
			<if test="bean.userId != null">
				 user_id = #{bean.userId},
			</if>
			<if test="bean.videoId != null">
				 video_id = #{bean.videoId},
			</if>
			<if test="bean.progress != null">
				 progress = #{bean.progress},
			</if>
			<if test="bean.lastWatchTime != null">
				 last_watch_time = #{bean.lastWatchTime},
			</if>
			<if test="bean.watchDuration != null">
				 watch_duration = #{bean.watchDuration},
			</if>
			<if test="bean.createdAt != null">
				 created_at = #{bean.createdAt},
			</if>
			<if test="bean.updatedAt != null">
				 updated_at = #{bean.updatedAt},
			</if>
 		 </set>
 		 where id=#{id}
	</update>

	<!-- 根据Id删除-->
	<delete id="deleteById">
		delete from video_history where id=#{id}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectById" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from video_history v where id=#{id}
	</select>

	<!-- 根据UserIdAndVideoId修改-->
	<update id="updateByUserIdAndVideoId" parameterType="com.shipin.entity.po.VideoHistory">
		 UPDATE video_history
 		 <set> 
			<if test="bean.progress != null">
				 progress = #{bean.progress},
			</if>
			<if test="bean.lastWatchTime != null">
				 last_watch_time = #{bean.lastWatchTime},
			</if>
			<if test="bean.watchDuration != null">
				 watch_duration = #{bean.watchDuration},
			</if>
			<if test="bean.createdAt != null">
				 created_at = #{bean.createdAt},
			</if>
			<if test="bean.updatedAt != null">
				 updated_at = #{bean.updatedAt},
			</if>
 		 </set>
 		 where user_id=#{userId} and video_id=#{videoId}
	</update>

	<!-- 根据UserIdAndVideoId删除-->
	<delete id="deleteByUserIdAndVideoId">
		delete from video_history where user_id=#{userId} and video_id=#{videoId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByUserIdAndVideoId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from video_history v where user_id=#{userId} and video_id=#{videoId}
	</select>


	<select id="getVideoHistory" resultMap="history_with_video_result_map" >
		SELECT  vh.*,v.title, u.nick_name,v.cover_url,v.duration FROM `video_history` vh
		join video v on v.video_id = vh.video_id
		join user u on u.user_id = v.user_id
		where vh.user_id = #{query.userId}
		order by vh.last_watch_time desc
	</select>

	<select id="searchVideoHistory" resultMap="history_with_video_result_map">
		SELECT
			vh.*,
			v.title,
			u.nick_name,
			v.cover_url,
			v.duration
		FROM `video_history` vh
				 JOIN video v ON v.video_id = vh.video_id
				 JOIN user u ON u.user_id = v.user_id
		WHERE
			vh.user_id = #{userId}
		  AND (  -- 括号包裹OR条件，确保先匹配标题/昵称，再限定用户ID
			v.title LIKE CONCAT('%', #{keyword}, '%')
				OR u.nick_name LIKE CONCAT('%', #{keyword}, '%')
			)
	</select>
</mapper>