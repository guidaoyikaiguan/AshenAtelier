		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="com.shipin.entity.po.VideoHistory" useGeneratedKeys="true" keyProperty="id">
		 INSERT INTO video_history(
			 user_id,
			 video_id,
			 progress,
			 last_watch_time,
			 watch_duration,
			 created_at,
			 updated_at
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.userId},
				 #{item.videoId},
				 #{item.progress},
				 #{item.lastWatchTime},
				 #{item.watchDuration},
				 #{item.createdAt},
				 #{item.updatedAt}
			 )
		 </foreach>
	</insert>

	<!-- 批量新增修改 （批量插入）-->
	<insert id="insertOrUpdateBatch" parameterType="com.shipin.entity.po.VideoHistory">
		 INSERT INTO video_history(
			 user_id,
			 video_id,
			 progress,
			 last_watch_time,
			 watch_duration,
			 created_at,
			 updated_at
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
