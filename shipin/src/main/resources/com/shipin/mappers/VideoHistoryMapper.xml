				 user_id = VALUES(user_id),
			</if>
			<if test="bean.videoId!=null">
				 video_id = VALUES(video_id),
			</if>
			<if test="bean.progress!=null">
				 progress = VALUES(progress),
			</if>
			<if test="bean.lastWatchTime!=null">
				 last_watch_time = VALUES(last_watch_time),
			</if>
			<if test="bean.watchDuration!=null">
