			watch_duration = VALUES(watch_duration),
			created_at = VALUES(created_at),
			updated_at = VALUES(updated_at)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="com.shipin.entity.query.VideoHistoryQuery">
		 UPDATE video_history v
 		 <set> 
			<if test="bean.userId != null">
				 user_id = #{bean.userId},
			</if>
			<if test="bean.videoId != null">
				 video_id = #{bean.videoId},
			</if>
			<if test="bean.progress != null">
				 progress = #{bean.progress},
			</if>
			<if test="bean.lastWatchTime != null">
